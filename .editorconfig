root = true

[*.cs]
indent_style = space
indent_size = 4
charset = utf-8-bom
end_of_line = crlf
insert_final_newline = true

# ==========================================================
# MiKiNuo MVI Analyzer 策略
# 只把三类规则作为编译失败条件：
# 1. Clean Architecture 分层引用规则。
# 2. 微软 C# 编码规范中影响公共 API、可维护性、命名和资源安全的规则。
# 3. 类、方法、属性、字段、常量、接口等中文 XML 注释规则。
# 纯风格偏好，例如主构造函数、集合表达式、简化 if，不作为 error。
# ==========================================================

# ---------- 微软编码规范：必须严格执行 ----------
dotnet_style_require_accessibility_modifiers = always:error
csharp_style_namespace_declarations = file_scoped:error
csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_elsewhere = false:error

dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access = true:error
dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_qualification_for_event = false:error

# ---------- 微软质量规则：必须严格执行 ----------
dotnet_diagnostic.CA1716.severity = error
dotnet_diagnostic.CA1816.severity = error
dotnet_diagnostic.CA1001.severity = error
dotnet_diagnostic.CA1062.severity = error
dotnet_diagnostic.CA2000.severity = error

dotnet_diagnostic.IDE0008.severity = error
dotnet_diagnostic.IDE0040.severity = error

# ---------- XML 注释：必须严格执行 ----------
dotnet_diagnostic.CS1591.severity = error

dotnet_diagnostic.DOC0001.severity = error
dotnet_diagnostic.DOC0002.severity = error
dotnet_diagnostic.DOC0003.severity = error
dotnet_diagnostic.DOC0004.severity = error
dotnet_diagnostic.DOC0005.severity = error
dotnet_diagnostic.DOC0006.severity = error
dotnet_diagnostic.DOC0007.severity = error
dotnet_diagnostic.DOC0008.severity = error

# ---------- Clean Architecture：必须严格执行 ----------
dotnet_diagnostic.ARCH0001.severity = error
dotnet_diagnostic.ARCH0002.severity = error
dotnet_diagnostic.ARCH0003.severity = error
dotnet_diagnostic.ARCH0004.severity = error
dotnet_diagnostic.ARCH0005.severity = error
dotnet_diagnostic.ARCH0006.severity = error
dotnet_diagnostic.ARCH0007.severity = error

# ---------- 纯风格偏好：不阻断编译 ----------
dotnet_diagnostic.IDE0028.severity = suggestion
dotnet_diagnostic.IDE0046.severity = suggestion
dotnet_diagnostic.IDE0058.severity = suggestion
dotnet_diagnostic.IDE0290.severity = suggestion
dotnet_diagnostic.IDE0300.severity = suggestion
dotnet_diagnostic.IDE0301.severity = suggestion

# 不再把整类 Style / Design / Performance 一刀切设为 error，避免把语法糖偏好升级为编译失败。
dotnet_analyzer_diagnostic.category-Style.severity = suggestion
dotnet_analyzer_diagnostic.category-Design.severity = suggestion
dotnet_analyzer_diagnostic.category-Performance.severity = suggestion
dotnet_analyzer_diagnostic.category-Reliability.severity = error

dotnet_diagnostic.CODE0001.severity = error
dotnet_diagnostic.CODE0002.severity = error
