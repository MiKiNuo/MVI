<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.EventBindingWorkbench.EventBindingSearchPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12">
        <StackPanel Spacing="8">
            <TextBlock Text="SearchPanel" FontWeight="SemiBold" />
            <TextBox
                x:Name="QueryTextBox"
                PlaceholderText="输入患者关键字" />
            <TextBlock Text="{Binding QueryText}" />
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#64748B" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
