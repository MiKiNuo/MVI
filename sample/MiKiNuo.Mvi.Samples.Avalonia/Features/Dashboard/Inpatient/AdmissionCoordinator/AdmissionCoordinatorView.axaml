<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Inpatient.AdmissionCoordinator.AdmissionCoordinatorView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="12">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="入院登记表单" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="护士录入患者资料后提交，兄弟 MVI 自动接收并处理" Foreground="#64748B" FontSize="12" />
                </StackPanel>
                <Border Grid.Column="1" Background="#DBEAFE" CornerRadius="10" Padding="8,3">
                    <TextBlock Text="住院" Foreground="#1D4ED8" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                <StackPanel>
                    <TextBlock Text="患者姓名" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding PatientName, Mode=TwoWay}" PlaceholderText="例如：张三" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="年龄" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding PatientAge, Mode=TwoWay}" PlaceholderText="例如：68" />
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <TextBlock Text="入院诊断" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding AdmissionDiagnosis, Mode=TwoWay}" PlaceholderText="例如：急性心衰" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="目标床号" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding TargetBedNo, Mode=TwoWay}" PlaceholderText="例如：A12-08" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                    <TextBlock Text="护士交接备注" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding NurseNote, Mode=TwoWay}" PlaceholderText="过敏史、跌倒风险、管路情况等" AcceptsReturn="True" MinHeight="56" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="2*,*" ColumnSpacing="8">
                <Button Content="{Binding ConfirmAdmissionText}" Command="{Binding SubmitAdmissionCommand}" />
                <Button Grid.Column="1" Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}" />
            </Grid>

            <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="8" Padding="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding StatusText}" Foreground="#0F766E" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" Foreground="#475569" />
                    <TextBlock Text="{Binding ActionLog}" TextWrapping="Wrap" Foreground="#334155" />
                </StackPanel>
            </Border>

            <Button Grid.Row="4" Content="模拟传统流程动作" Command="{Binding PrimaryActionCommand}" />
        </Grid>
    </Border>
</UserControl>
