<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Lab.CriticalValueMonitor.CriticalValueMonitorView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="Auto,*">
                <Border Width="28" Height="28" Background="#0EA5E9" CornerRadius="14">
                    <TextBlock Text="L" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Margin="8,4,0,0" />
            </Grid>
            <Border Grid.Row="1" Background="#F0F9FF" CornerRadius="8" Padding="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding MainValue}" FontSize="20" FontWeight="Bold" Foreground="#0369A1" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#0F766E" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Grid Grid.Row="2" ColumnDefinitions="4,*" ColumnSpacing="8">
                <Border Background="#38BDF8" CornerRadius="2" />
                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" Foreground="#475569" />
                    <TextBlock Text="{Binding ActionLog}" TextWrapping="Wrap" Foreground="#075985" />
                </StackPanel>
            </Grid>
            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Content="{Binding PrimaryActionText}" Command="{Binding PrimaryActionCommand}" />
                <Button Grid.Column="1" Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
