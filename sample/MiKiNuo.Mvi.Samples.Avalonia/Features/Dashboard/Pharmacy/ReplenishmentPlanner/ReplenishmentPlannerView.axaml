<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Pharmacy.ReplenishmentPlanner.ReplenishmentPlannerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Foreground="#C2410C" FontWeight="SemiBold" />
                </StackPanel>
                <Border Grid.Column="1" Background="#FFEDD5" CornerRadius="8" Padding="8">
                    <TextBlock Text="{Binding MainValue}" Foreground="#9A3412" FontWeight="Bold" />
                </Border>
            </Grid>
            <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="8">
                <Border Background="#FFF7ED" CornerRadius="8" Padding="8">
                    <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" Foreground="#475569" />
                </Border>
                <Border Grid.Row="1" Background="#FEF2F2" CornerRadius="8" Padding="8">
                    <TextBlock Text="{Binding ActionLog}" TextWrapping="Wrap" Foreground="#991B1B" />
                </Border>
            </Grid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}" />
                <Button Content="{Binding PrimaryActionText}" Command="{Binding PrimaryActionCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
