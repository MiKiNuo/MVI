<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Pharmacy.PrescriptionReviewBoard.PrescriptionReviewBoardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="12">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="处方审核录入" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="药师录入处方和用药信息后，库存、补货和安全组件联动" Foreground="#64748B" FontSize="12" />
                </StackPanel>
                <Border Grid.Column="1" Background="#DCFCE7" CornerRadius="10" Padding="8,3">
                    <TextBlock Text="PIS" Foreground="#15803D" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                <StackPanel>
                    <TextBlock Text="处方号" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding PrescriptionNo, Mode=TwoWay}" Watermark="例如：RX20260502008" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="患者姓名" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding PatientName, Mode=TwoWay}" Watermark="例如：李四" />
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <TextBlock Text="药品名称" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding DrugName, Mode=TwoWay}" Watermark="例如：头孢曲松钠" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="剂量用法" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding DoseText, Mode=TwoWay}" Watermark="例如：2g ivgtt qd" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                    <TextBlock Text="过敏史/药师备注" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding AllergyHistory, Mode=TwoWay}" Watermark="青霉素过敏、肾功能异常、需皮试等" AcceptsReturn="True" MinHeight="56" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="2*,*" ColumnSpacing="8">
                <Button Content="{Binding ApprovePrescriptionText}" Command="{Binding SubmitPrescriptionReviewCommand}" />
                <Button Grid.Column="1" Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}" />
            </Grid>

            <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="8" Padding="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding StatusText}" Foreground="#15803D" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" Foreground="#475569" />
                    <TextBlock Text="{Binding ActionLog}" TextWrapping="Wrap" Foreground="#334155" />
                </StackPanel>
            </Border>

            <Button Grid.Row="4" Content="模拟自动审方规则" Command="{Binding PrimaryActionCommand}" />
        </Grid>
    </Border>
</UserControl>
