<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Quality.QualityKpiBoard.QualityKpiBoardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="Auto,*">
                <Border Width="64" Height="64" Background="#F5F3FF" CornerRadius="32">
                    <TextBlock Text="{Binding MainValue}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#6D28D9" FontWeight="Bold" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Foreground="#7C3AED" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" Foreground="#475569" />
                </StackPanel>
            </Grid>
            <Border Grid.Row="1" Background="#FAF5FF" CornerRadius="8" Padding="8">
                <TextBlock Text="{Binding ActionLog}" TextWrapping="Wrap" Foreground="#581C87" />
            </Border>
            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Content="{Binding PrimaryActionText}" Command="{Binding PrimaryActionCommand}" />
                <Button Grid.Column="1" Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
