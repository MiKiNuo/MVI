<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Quality.RiskEventBoard.RiskEventBoardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="12">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="风险事件上报" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="质控员录入风险事件后，KPI、病历质控和整改闭环联动" Foreground="#64748B" FontSize="12" />
                </StackPanel>
                <Border Grid.Column="1" Background="#FEE2E2" CornerRadius="10" Padding="8,3">
                    <TextBlock Text="质控" Foreground="#B91C1C" FontSize="12" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                <StackPanel>
                    <TextBlock Text="事件标题" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding EventTitle, Mode=TwoWay}" PlaceholderText="例如：抗菌药物越级使用" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="责任科室" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding DepartmentName, Mode=TwoWay}" PlaceholderText="例如：呼吸内科" />
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <TextBlock Text="风险等级" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding SeverityLevel, Mode=TwoWay}" PlaceholderText="低/中/高/严重" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="责任人" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding ResponsibleOwner, Mode=TwoWay}" PlaceholderText="例如：王医生" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                    <TextBlock Text="整改措施" FontSize="12" Foreground="#475569" />
                    <TextBox Text="{Binding CorrectiveAction, Mode=TwoWay}" PlaceholderText="立即暂停医嘱、科主任复核、药事会追踪等" AcceptsReturn="True" MinHeight="56" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="2*,*" ColumnSpacing="8">
                <Button Content="{Binding SubmitRiskEventText}" Command="{Binding SubmitRiskEventCommand}" />
                <Button Grid.Column="1" Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}" />
            </Grid>

            <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="8" Padding="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding StatusText}" Foreground="#B91C1C" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" Foreground="#475569" />
                    <TextBlock Text="{Binding ActionLog}" TextWrapping="Wrap" Foreground="#334155" />
                </StackPanel>
            </Border>

            <Button Grid.Row="4" Content="模拟升级高风险" Command="{Binding PrimaryActionCommand}" />
        </Grid>
    </Border>
</UserControl>
