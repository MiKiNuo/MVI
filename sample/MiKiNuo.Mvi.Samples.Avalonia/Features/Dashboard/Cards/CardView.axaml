<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Cards.CardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cards="clr-namespace:MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Cards"
    xmlns:bedCatalog="clr-namespace:MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Inpatient.BedCatalog">
    <Border Background="{DynamicResource BrushSurface}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="0">
        <Grid RowDefinitions="Auto,*,Auto">
            <!-- 1. 顶部：SourceKey 色彩头 + 标题 + 流程状态徽章 -->
            <Border Grid.Row="0" Padding="14,12,14,10"
                    Background="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Soft}"
                    BorderBrush="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}" />
                        <TextBlock Text="{Binding SourceDisplayName}" FontSize="10" FontWeight="Bold"
                                   Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}"
                                   VerticalAlignment="Center" LetterSpacing="1.2" />
                        <Border Background="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                                Padding="6,1" CornerRadius="4" Margin="6,0,0,0">
                            <TextBlock Text="{Binding SourceKey}" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- 2. 中部：指标 + 状态 + 详情 + 表单 -->
            <Border Grid.Row="1" Padding="14,12,14,12">
                <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2,0,0">
                    <TextBlock Text="{Binding MainValue}" FontSize="22" FontWeight="Bold"
                               Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}" />
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               VerticalAlignment="Bottom" Margin="0,0,0,4"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Background="{DynamicResource BrushSurfaceMuted}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="10,8">
                    <TextBlock Text="{Binding DetailText}" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               TextWrapping="Wrap" LineHeight="16" />
                </Border>

                <!-- 床位目录筛选：仅 BedOverview 卡片显示；用 ComboBox + CheckBox 多选 + DataGrid 让 UI 更丰富。 -->
                <StackPanel IsVisible="{Binding ShowBedCatalog}" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}" />
                        <TextBlock Text="床位状态筛选" FontSize="10" FontWeight="Bold"
                                   Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}"
                                   LetterSpacing="1.2" VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox x:Name="BedFilterComboBox"
                              ItemsSource="{Binding AvailableBedFilters}"
                              SelectedItem="{Binding SelectedBedFilterOption, Mode=OneWay}"
                              SelectionChanged="OnBedFilterSelectionChanged"
                              HorizontalAlignment="Stretch"
                              FontSize="12" Padding="10,6"
                              PlaceholderText="请选择床位状态">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="bedCatalog:BedFilterOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- 床位类型多选（CheckBox 组）：与 ComboBox 叠加生效；空选 = 不限类型。 -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="床位类型多选" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextMuted}" LetterSpacing="0.5" />
                        <ItemsControl ItemsSource="{Binding AvailableBedTypes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="bedCatalog:BedTypeOption">
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsCheckedChanged="OnBedTypeCheckBoxChanged"
                                              Tag="{Binding Value}"
                                              FontSize="11" Margin="0,0,8,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 床位状态多选（CheckBox 组）：与 ComboBox 叠加生效；空选 = 不限状态。 -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="床位状态多选" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextMuted}" LetterSpacing="0.5" />
                        <ItemsControl ItemsSource="{Binding AvailableBedStatuses}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="bedCatalog:BedStatusOption">
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsCheckedChanged="OnBedStatusCheckBoxChanged"
                                              Tag="{Binding Value}"
                                              FontSize="11" Margin="0,0,8,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Background="{DynamicResource BrushSurfaceMuted}"
                            BorderBrush="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                            BorderThickness="1" CornerRadius="6" Padding="8,6">
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}">
                                <Run Text="当前筛选：" />
                                <Run Text="{Binding SelectedBedFilterOption.DisplayName}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource BrushTextPrimary}" />
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="匹配床位数：" FontSize="10" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushTextMuted}" />
                                <TextBlock Text="{Binding FilteredBedCount}" FontSize="18" FontWeight="Bold"
                                           Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}" />
                                <TextBlock FontSize="10" VerticalAlignment="Bottom" Margin="0,0,0,2"
                                           Foreground="{DynamicResource BrushTextMuted}">
                                    <Run Text=" / " />
                                    <Run Text="{Binding FilteredBedCount}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid：按当前筛选条件展示 BedRecordRow 列表，列以中文 header + 中文展示字段名绑定。 -->
                    <Border Background="{DynamicResource BrushSurfaceMuted}"
                            BorderBrush="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                            BorderThickness="1" CornerRadius="6" Padding="0">
                        <DataGrid x:Name="FilteredBedsDataGrid"
                                  ItemsSource="{Binding FilteredBedRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  MaxHeight="200"
                                  FontSize="11"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="床号" Binding="{Binding BedNo}" Width="100" />
                                <DataGridTextColumn Header="病区" Binding="{Binding Ward}" Width="80" />
                                <DataGridTextColumn Header="类型" Binding="{Binding TypeDisplay}" Width="80" />
                                <DataGridTextColumn Header="状态" Binding="{Binding StatusDisplay}" Width="80" />
                                <DataGridTextColumn Header="患者" Binding="{Binding PatientName}" Width="*" />
                                <DataGridTextColumn Header="主治医师" Binding="{Binding PrimaryDoctor}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- 最近入院 Section：仅当兄弟入院登记卡提交后流入新患者时显示 -->
                <Border Background="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Soft}"
                        BorderBrush="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                        BorderThickness="1" CornerRadius="8" Padding="10,8"
                        IsVisible="{Binding HasRecentPatient}">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}" />
                            <TextBlock Text="最近入院" FontSize="10" FontWeight="Bold"
                                       Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}"
                                       LetterSpacing="1.2" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding RecentPatient.Name}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}" />
                            <TextBlock Text="→" FontSize="12" Foreground="{DynamicResource BrushTextMuted}" />
                            <TextBlock Text="{Binding RecentPatient.BedNo}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{Binding SourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}" />
                        </StackPanel>
                        <TextBlock Text="{Binding RecentPatient.Diagnosis}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding RecentPatient.NurseNote, StringFormat='备注：{0}'}"
                                   FontSize="10" Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Form 字段区：仅当 IsFormCard=true 时显示 -->
                <StackPanel IsVisible="{Binding IsFormCard}" Spacing="6">
                    <ItemsControl ItemsSource="{Binding FormFields}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type cards:CardFormFieldEntry}">
                                <StackPanel Spacing="2" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextMuted}" LetterSpacing="0.5" />
                                    <TextBox Text="{Binding Value, Mode=TwoWay}" PlaceholderText="{Binding InputHint}"
                                             FontSize="12" Padding="8,6" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding FormErrorMessage}" Foreground="#B91C1C" FontSize="11"
                               IsVisible="{Binding HasFormError}" />
                </StackPanel>
                </StackPanel>
            </Border>

            <!-- 3. 底部：操作按钮 + 数据流状态条 -->
            <Border Grid.Row="2" Padding="14,8,14,12"
                    Background="{DynamicResource BrushSurfaceMuted}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding PrimaryActionText}" Command="{Binding PrimaryActionCommand}"
                                Padding="12,6" FontSize="12" />
                        <Button Content="{Binding SecondaryActionText}" Command="{Binding SecondaryActionCommand}"
                                Padding="12,6" FontSize="12" />
                        <Button Content="提交" Command="{Binding SubmitFormCommand}"
                                IsVisible="{Binding IsFormCard}"
                                Padding="12,6" FontSize="12" />
                    </StackPanel>

                    <!-- 数据流状态：根据 ActionLog 内容显示「已派发」或「已接收」 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Ellipse Width="6" Height="6"
                                 Fill="{Binding ActionLog, Converter={x:Static cards:ActionLogFlowIndicatorConverter.Instance}}" />
                        <TextBlock Text="数据流" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextMuted}" LetterSpacing="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActionLog}" FontSize="10"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   TextTrimming="CharacterEllipsis" MaxLines="1"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
