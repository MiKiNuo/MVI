<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.ArchitectureValidation.ArchitectureValidationView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mvi="clr-namespace:MiKiNuo.Mvi.Platforms.Avalonia.Slot;assembly=MiKiNuo.Mvi.Platforms.Avalonia">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="14" Padding="14">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" Foreground="#475569" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.1*,1.4*,1.2*" RowDefinitions="*,*" ColumnSpacing="12" RowSpacing="12">
            <Border Grid.RowSpan="2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="14" Padding="10">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="复用 MVI：患者检索" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <mvi:MviSlotHost x:Name="PatientSearchSlot" Grid.Row="1" />
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="14" Padding="10">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="4 大架构支柱指标卡（静态）" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                        <mvi:MviSlotHost x:Name="MiddlewareMetricSlot" />
                        <mvi:MviSlotHost x:Name="ReuseMetricSlot" Grid.Column="1" />
                        <mvi:MviSlotHost x:Name="MediatorMetricSlot" Grid.Row="1" />
                        <mvi:MviSlotHost x:Name="EffectMetricSlot" Grid.Row="1" Grid.Column="1" />
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Column="1" Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="14" Padding="12">
                <StackPanel>
                    <TextBlock Text="演示索引：4 大支柱 ↔ MVI 组件" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Foreground="#0F172A">
                        <Run Text="• " FontWeight="SemiBold" />
                        <Run Text="中间件：" FontWeight="SemiBold" />
                        <Run Text="MviStore ↔ MviMiddleware（请求/响应/事件串联）。" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#0F172A" Margin="0,4,0,0">
                        <Run Text="• " FontWeight="SemiBold" />
                        <Run Text="复用组件：" FontWeight="SemiBold" />
                        <Run Text="左右两侧患者检索 + 审计时间线在 4 个生产页面共用同一对 ViewModel。" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#0F172A" Margin="0,4,0,0">
                        <Run Text="• " FontWeight="SemiBold" />
                        <Run Text="中介者：" FontWeight="SemiBold" />
                        <Run Text="IMviMediator 的 Request/Response + Subscribe/Publish 路由。" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#0F172A" Margin="0,4,0,0">
                        <Run Text="• " FontWeight="SemiBold" />
                        <Run Text="副作用：" FontWeight="SemiBold" />
                        <Run Text="IMviEffectDispatcher 在 reducer 派发后完成 IO / 导航 / 跨组件派发。" />
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#2563EB" Margin="0,10,0,0">
                        <Run Text="→ 端到端业务流转请到「住院床位 / 检验医嘱 / 药房库存 / 运营质控」4 个生产页面验证。" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Grid.RowSpan="2" Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="14" Padding="10">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="复用 MVI：审计时间线" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <mvi:MviSlotHost x:Name="AuditTimelineSlot" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
