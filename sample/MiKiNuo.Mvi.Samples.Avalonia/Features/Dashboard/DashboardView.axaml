<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.DashboardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mvi="clr-namespace:MiKiNuo.Mvi.Platforms.Avalonia.Slot;assembly=MiKiNuo.Mvi.Platforms.Avalonia">
    <Grid ColumnDefinitions="260,*" RowDefinitions="Auto,*" ColumnSpacing="14" RowSpacing="14" Margin="16">
        <mvi:MviSlotHost x:Name="HeaderSlot" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" ComponentId="DashboardHeader" />
        <Border Grid.Column="0" Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="10">
            <mvi:MviSlotHost x:Name="MenuSlot" ComponentId="DashboardMenu" />
        </Border>
        <Border Grid.Column="1" Grid.Row="1" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="14">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentPageTitle}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentPageDescription}" FontSize="13" Foreground="#64748B" TextWrapping="Wrap" />
                </StackPanel>
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <mvi:MviSlotHost x:Name="PageSlot" ComponentId="CurrentBusinessPage" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
