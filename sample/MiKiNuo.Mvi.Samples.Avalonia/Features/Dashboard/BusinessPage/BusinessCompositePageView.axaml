<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.BusinessPage.BusinessCompositePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mvi="clr-namespace:MiKiNuo.Mvi.Platforms.Avalonia.Slot;assembly=MiKiNuo.Mvi.Platforms.Avalonia">
    <Grid RowDefinitions="Auto,*,170" RowSpacing="12">
        <Grid ColumnDefinitions="2*,*" ColumnSpacing="12">
            <Border Background="#EFF6FF" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding ScenarioTitle}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ScenarioSummary}" Foreground="#475569" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Grid Grid.Column="1" RowDefinitions="*,*" RowSpacing="8">
                <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="10">
                    <StackPanel>
                        <TextBlock Text="当前业务上下文" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ActiveContext}" Foreground="#334155" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Background="#F0FDFA" BorderBrush="#99F6E4" BorderThickness="1" CornerRadius="12" Padding="10">
                    <StackPanel>
                        <TextBlock Text="流程状态" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding FlowStatus}" Foreground="#0F766E" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <!-- 住院床位：指挥中心布局，床位总览占左侧主区域，入院流程纵向贯穿中间，护理任务和风险面板在右侧联动。 -->
            <Grid x:Name="InpatientLayout" ColumnDefinitions="1.35*,1*,1.1*" RowDefinitions="*,*" ColumnSpacing="12" RowSpacing="12" IsVisible="False">
                <Border Grid.RowSpan="2" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="病区床位沙盘" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="InpatientBedOverviewSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Column="1" Grid.RowSpan="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="入院协调纵向流程" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="InpatientAdmissionSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Column="2" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="护理任务看板" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="InpatientNursingSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Column="2" Grid.Row="1" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="病区风险雷达" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="InpatientRiskSlot" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 检验医嘱：流水线布局，从医嘱开立到标本流转，再到危急值和 TAT，体现串联流程。 -->
            <Grid x:Name="LabLayout" RowDefinitions="Auto,*,1.1*" ColumnDefinitions="*,*,*" ColumnSpacing="12" RowSpacing="12" IsVisible="False">
                <Border Grid.ColumnSpan="3" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="14" Padding="10">
                    <TextBlock Text="检验闭环流水线：医嘱开立 → 标本采集/运输/签收 → 上机检测 → 危急值确认 → TAT 预警" FontWeight="SemiBold" Foreground="#075985" />
                </Border>
                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="① 医嘱开立区" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="LabOrderSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="② 标本流转区" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="LabSpecimenSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="③ 危急值闭环" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="LabCriticalSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#ECFEFF" BorderBrush="#A5F3FC" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="④ TAT 实时监控与超时追踪" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="LabTatSlot" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 药房库存：处方驱动布局，左侧审核流，中间库存水位，右侧补货与安全决策。 -->
            <Grid x:Name="PharmacyLayout" ColumnDefinitions="1.1*,1.4*,1.1*" RowDefinitions="1.1*,*" ColumnSpacing="12" RowSpacing="12" IsVisible="False">
                <Border Grid.RowSpan="2" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="处方审核队列" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="PharmacyPrescriptionSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Column="1" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="库存水位与药品批号" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="PharmacyStockSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Column="1" Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="补货计划与采购建议" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="PharmacyReplenishmentSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Column="2" Grid.RowSpan="2" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="用药安全与拦截规则" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="PharmacySafetySlot" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 运营质控：驾驶舱布局，顶部 KPI 总览，底部三栏形成缺陷、风险、整改闭环。 -->
            <Grid x:Name="QualityLayout" RowDefinitions="1.15*,*" ColumnDefinitions="*,*,*" ColumnSpacing="12" RowSpacing="12" IsVisible="False">
                <Border Grid.ColumnSpan="3" Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="院级质量 KPI 驾驶舱" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="QualityKpiSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="病历缺陷抽查" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="QualityAuditSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="风险事件分级" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="QualityRiskSlot" Grid.Row="1" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="14" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="整改闭环追踪" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <mvi:MviSlotHost x:Name="QualityRectificationSlot" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="10">
            <StackPanel>
                <TextBlock Text="组合式 MVI 数据流日志" Foreground="#0F172A" FontWeight="SemiBold" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding InteractionLog}" Foreground="#0369A1" TextWrapping="Wrap" />
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
