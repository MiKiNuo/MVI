<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.BusinessPage.BusinessCompositePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cards="clr-namespace:MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Cards"
    xmlns:mvi="clr-namespace:MiKiNuo.Mvi.Platforms.Avalonia.Slot;assembly=MiKiNuo.Mvi.Platforms.Avalonia">
    <Grid RowDefinitions="Auto,*,170" RowSpacing="12">
        <!-- 顶部：场景标题 + 流程摘要 + 上下文/状态（按业务域着色） -->
        <Border Grid.Row="0" Padding="16,14,16,14"
                Background="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Soft}"
                BorderBrush="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                BorderThickness="1" CornerRadius="14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                <!-- 业务域图标 + 标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}">
                        <!-- 数据流图标：① 节点 → ② 节点 -->
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M3,12 L10,12 M8,9 L10,12 L8,15 M14,12 L21,12 M19,9 L21,12 L19,15 M3,12 L3,18 L21,18 M3,18 L0,18 M3,18 L3,21 M21,18 L24,18"
                                  Stroke="White" StrokeThickness="1.8"
                                  StrokeLineCap="Round" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding ScenarioTitle}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}" />
                        <TextBlock Text="{Binding FlowSummary}" FontSize="12"
                                   Foreground="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}"
                                   Opacity="0.85" />
                    </StackPanel>
                </StackPanel>
                <!-- 右侧：上下文 / 流程状态（与左下角 ④ 节点对齐） -->
                <Border Grid.Column="2" Background="{DynamicResource BrushSurface}"
                        BorderBrush="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Border}"
                        BorderThickness="1" CornerRadius="10" Padding="10,6" VerticalAlignment="Center">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="6" Height="6"
                                     Fill="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}" />
                            <TextBlock Text="上下文" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextMuted}" LetterSpacing="0.5" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveContext}" FontSize="11"
                                   Foreground="{DynamicResource BrushTextPrimary}" TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding FlowStatus}" FontSize="10"
                                   Foreground="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Dark}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 中部：统一 2×2 「数据流节点」布局（Z 形：① → ② → ③ → ④） -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto,*" ColumnDefinitions="*,Auto,*"
              RowSpacing="0" ColumnSpacing="0">
            <!-- ① 节点 左上 -->
            <Border Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                <mvi:MviSlotHost x:Name="Node1Slot" />
            </Border>
            <!-- ① → ② 横向数据流箭头 + 标签 -->
            <Grid Grid.Row="0" Grid.Column="1" Width="56" Margin="0,0,0,8"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Path Grid.Row="0" Data="M2,18 L46,18 M40,12 L46,18 L40,24"
                      Stroke="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}"
                      StrokeThickness="2.5" StrokeLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Border Grid.Row="1" HorizontalAlignment="Center" Margin="0,2,0,0"
                        Background="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}"
                        CornerRadius="4" Padding="6,1">
                    <TextBlock Text="{Binding FlowLabel12}" FontSize="10" FontWeight="SemiBold"
                               Foreground="White" />
                </Border>
            </Grid>
            <!-- ② 节点 右上 -->
            <Border Grid.Row="0" Grid.Column="2" Margin="8,0,0,8">
                <mvi:MviSlotHost x:Name="Node2Slot" />
            </Border>

            <!-- ② → ③ 纵向数据流箭头 + 标签（位于右列） -->
            <Grid Grid.Row="1" Grid.Column="2" Height="56" Margin="8,0,0,0"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0" Data="M18,2 L18,46 M12,40 L18,46 L24,40"
                      Stroke="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}"
                      StrokeThickness="2.5" StrokeLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Border Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"
                        Background="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}"
                        CornerRadius="4" Padding="6,1">
                    <TextBlock Text="{Binding FlowLabel23}" FontSize="10" FontWeight="SemiBold"
                               Foreground="White" />
                </Border>
            </Grid>

            <!-- ④ 节点 左下 -->
            <Border Grid.Row="2" Grid.Column="0" Margin="0,8,8,0">
                <mvi:MviSlotHost x:Name="Node4Slot" />
            </Border>
            <!-- ③ → ④ 横向数据流箭头 + 标签（反向：右 → 左） -->
            <Grid Grid.Row="2" Grid.Column="1" Width="56" Margin="0,8,0,0"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,2"
                        Background="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}"
                        CornerRadius="4" Padding="6,1">
                    <TextBlock Text="{Binding FlowLabel34}" FontSize="10" FontWeight="SemiBold"
                               Foreground="White" />
                </Border>
                <Path Grid.Row="1" Data="M46,18 L2,18 M8,12 L2,18 L8,24"
                      Stroke="{Binding DomainSourceKey, Converter={x:Static cards:CardSourceBrushConverter.Instance}, ConverterParameter=Base}"
                      StrokeThickness="2.5" StrokeLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
            <!-- ③ 节点 右下 -->
            <Border Grid.Row="2" Grid.Column="2" Margin="8,8,0,0">
                <mvi:MviSlotHost x:Name="Node3Slot" />
            </Border>
        </Grid>

        <!-- 底部：组合式 MVI 数据流日志 -->
        <Border Grid.Row="2" Background="{DynamicResource BrushSurface}"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource BrushFlowReceived}" />
                    <TextBlock Text="组合式 MVI 数据流日志" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="（父 → 子 → 兄弟卡片 → 父）" FontSize="10"
                               Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" />
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding InteractionLog}" FontSize="11"
                               Foreground="{DynamicResource BrushFlowSent}" TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
