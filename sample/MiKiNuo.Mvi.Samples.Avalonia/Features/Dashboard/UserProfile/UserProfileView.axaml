<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.UserProfile.UserProfileView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Padding="20">
        <StackPanel Spacing="10">
            <TextBlock Text="用户信息" FontSize="22" FontWeight="Bold" Foreground="#0F172A" />
            <TextBlock Text="{Binding DisplayName}" FontSize="18" Foreground="#334155" />
            <TextBlock Text="{Binding RoleName}" Foreground="#64748B" />
        </StackPanel>
    </Border>
</UserControl>
