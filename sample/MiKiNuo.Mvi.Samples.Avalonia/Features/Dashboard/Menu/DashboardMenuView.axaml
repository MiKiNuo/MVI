<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Menu.DashboardMenuView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:menu="clr-namespace:MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Menu">
    <Border Background="{DynamicResource BrushSurface}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="0">
            <!-- 顶部：工作区标题 + 搜索框 -->
            <StackPanel Grid.Row="0" Spacing="12" Margin="16,16,16,12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="{DynamicResource BrushDomainInpatientSoft}">
                        <TextBlock Text="M" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushDomainInpatientDark}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MVI 临床工作站" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}" />
                        <TextBlock Text="组合式 MVI 演示" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}" />
                    </StackPanel>
                </StackPanel>

                <Border Background="{DynamicResource BrushSurfaceMuted}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Data="M21 21l-4.35-4.35M11 6a5 5 0 100 10 5 5 0 000-10z"
                              Stroke="{DynamicResource BrushTextMuted}"
                              StrokeThickness="1.6" />
                        <TextBlock Text="搜索功能 (演示用)" FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Height="1" Margin="16,0"
                    Background="{DynamicResource BrushBorder}" />

            <!-- 中部：菜单列表（含选中态） -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="12,8">
                <ListBox ItemsSource="{Binding MenuItems}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,4" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <Panel>
                                        <!-- 选中态背景：左色条 + 浅色底 -->
                                        <Border IsVisible="{TemplateBinding IsSelected}"
                                                Background="{Binding DomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Soft}"
                                                BorderBrush="{Binding DomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Border}"
                                                BorderThickness="1" CornerRadius="8" Padding="10,8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Width="3" CornerRadius="2"
                                                        Background="{Binding DomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Base}" />
                                                <Border Width="22" Height="22" CornerRadius="6"
                                                        Background="{Binding DomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Soft}">
                                                    <Path Width="14" Height="14" Stretch="Uniform"
                                                          Data="{Binding IconKey, Converter={x:Static menu:IconKeyToGeometryConverter.Instance}}"
                                                          Stroke="{Binding DomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Dark}"
                                                          StrokeThickness="1.6" />
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <!-- 未选中态：图标 + 文字 -->
                                        <Border IsVisible="{TemplateBinding IsSelected, Converter={x:Static menu:InverseBooleanConverter.Instance}}"
                                                Background="Transparent" Padding="10,8" CornerRadius="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Width="3" CornerRadius="2" Background="Transparent" />
                                                <Border Width="22" Height="22" CornerRadius="6"
                                                        Background="{DynamicResource BrushSurfaceMuted}">
                                                    <Path Width="14" Height="14" Stretch="Uniform"
                                                          Data="{Binding IconKey, Converter={x:Static menu:IconKeyToGeometryConverter.Instance}}"
                                                          Stroke="{DynamicResource BrushTextMuted}"
                                                          StrokeThickness="1.6" />
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="13"
                                                           Foreground="{DynamicResource BrushTextSecondary}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                </ControlTemplate>
                            </Setter>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </ScrollViewer>

            <!-- 选中项详情卡：放在菜单与底部之间 -->
            <Border Grid.Row="3" Margin="14,4,14,12"
                    Background="{Binding SelectedItemDomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Soft}"
                    BorderBrush="{Binding SelectedItemDomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Border}"
                    BorderThickness="1" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="28" Height="28" CornerRadius="8"
                                Background="{Binding SelectedItemDomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Base}">
                            <Path Width="16" Height="16" Stretch="Uniform"
                                  Data="{Binding SelectedItemIconKey, Converter={x:Static menu:IconKeyToGeometryConverter.Instance}}"
                                  Stroke="White" StrokeThickness="1.8" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedMenuKey}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding SelectedItemCardCount, StringFormat={}{0}}" FontSize="11" FontWeight="Bold"
                                           Foreground="{Binding SelectedItemDomainKey, Converter={x:Static menu:DomainBrushConverter.Instance}, ConverterParameter=Dark}" />
                                <TextBlock Text="张协同卡片" FontSize="11"
                                           Foreground="{DynamicResource BrushTextMuted}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedItemDescription}" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 底部：数据流状态 -->
            <Border Grid.Row="4" Padding="16,12"
                    Background="{DynamicResource BrushSurfaceMuted}"
                    BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="#10B981" />
                        <TextBlock Text="数据流通道" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
