<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Outpatient.PatientQueue.PatientQueueView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel Spacing="10">
            <TextBlock Text="候诊队列 MVI" FontSize="17" FontWeight="SemiBold" />
            <TextBlock Text="{Binding QueueSummary}" Foreground="#475569" TextWrapping="Wrap" />
            <ListBox ItemsSource="{Binding Patients}" MinHeight="130" />
            <TextBlock Text="{Binding SelectedPatientName}" FontWeight="SemiBold" Foreground="#0F766E" />
            <Button Content="接诊下一位" Command="{Binding CallNextCommand}" />
        </StackPanel>
    </Border>
</UserControl>
