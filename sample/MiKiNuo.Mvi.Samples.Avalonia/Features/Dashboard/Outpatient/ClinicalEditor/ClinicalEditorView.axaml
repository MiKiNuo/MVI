<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Outpatient.ClinicalEditor.ClinicalEditorView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel Spacing="10">
            <TextBlock Text="电子病历编辑 MVI" FontSize="17" FontWeight="SemiBold" />
            <TextBlock Text="{Binding PatientName}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding RiskLevel}" Foreground="#B45309" />
            <TextBox PlaceholderText="输入初步诊断" Text="{Binding Diagnosis, Mode=TwoWay}" MinHeight="72" AcceptsReturn="True" />
            <Button Content="保存草稿" Command="{Binding SaveDraftCommand}" />
            <TextBlock Text="{Binding SaveMessage}" Foreground="#475569" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
