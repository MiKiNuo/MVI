<UserControl
    x:Class="MiKiNuo.Mvi.Samples.Avalonia.Features.Dashboard.Header.HeaderView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="16" Padding="20">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold" Foreground="#0F172A" />
            <TextBlock Text="{Binding SubTitle}" Foreground="#475569" />
        </StackPanel>
    </Border>
</UserControl>
